disp macro msg
    lea dx, msg
    mov ah,09h
    int 21h
endm

.model small
.stack
.data
    m1 db 10,13, "Enter String1: $"
    m2 db 10,13, "Enter String2: $"
    m3 db 10,13, "String 1 is equal to string 2: $"
    m4 db 10,13, "String 1 is not equal to string 2: $"
    m5 db 10,13, "Length of String1: $"
    m6 db 10,13, "Length of String2: $"
    str1 db 80 dup(40)
    str2 db 80 dup(40)
    l1 db ?
    l2 db ?

.code
    mov ax,@data
    mov ds,ax
    mov es,ax

    disp m1
    lea dx,str1
    call read

    disp m2
    lea dx,str2
    call read

    mov al, [str1+1]
    mov l1, al
    mov al, [str2+1]
    mov l2, al
    cmp al,l1
    jne strnote
    
    mov ch,0
    mov cl,l1
    lea si, str1+2
    lea di, str2+2
    cld
    repe cmpsb

    jne strnote
    disp m3
    jmp next
  strnote: disp m4
  next: disp m5
        mov al, l1
        call displ
        disp m6
        mov al, l2
        call displ
        mov ah, 4ch
        int 21h

    read proc
        mov ah, 0ah
        int 21h
        ret
    read endp

    displ proc
        aam
        mov bx,ax
        add bx,3030h
        mov ah,2
        mov dl,bh
        int 21h
        mov dl, bl
        int 21h
        ret
    displ endp
end